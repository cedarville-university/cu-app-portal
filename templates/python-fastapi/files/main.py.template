import os
from fastapi import FastAPI

app = FastAPI(title={{APP_NAME_JS}})


@app.get("/api/health")
def health():
    return {
        "status": "ok",
        "app": {{APP_NAME_JS}},
        "database": os.environ.get("DATABASE_URL") is not None,
    }


@app.get("/")
def root():
    return {
        "name": {{APP_NAME_JS}},
        "description": {{APP_DESCRIPTION_JS}},
        "runtime": "{{APP_SERVICE_RUNTIME}}",
    }
